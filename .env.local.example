DEV_MODE=true

# SMS провайдеры (раскомментируй нужный в продакшне)
# SMSC_LOGIN=your_login
# SMSC_PASSWORD=your_password
# SMSRU_API_KEY=your_api_key

# AI API для генерации карточек
GROQ_API_KEY=your_groq_api_key_here
# или
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram авторизация
# Имя бота без @, например my_cardai_bot
TELEGRAM_BOT_USERNAME=your_telegram_bot_username
# Секрет для подписи запросов бота к backend
TELEGRAM_BOT_SECRET=change_me_to_long_random_string
